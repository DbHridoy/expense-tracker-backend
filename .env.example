NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

DATABASE_URI=mongodb://127.0.0.1:27017/expense-tracker

JWT_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token

BCRYPT_SALT_ROUNDS=10

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=example@gmail.com
EMAIL_PASS=app-password
EMAIL_FROM_NAME=Expense Tracker
EMAIL_FROM_ADDRESS=example@gmail.com

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-s3-bucket
AWS_S3_ENDPOINT=

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=expense-tracker

SOCKET_PATH=/socket.io
SOCKET_TRANSPORTS=websocket,polling

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_DESTINATION=uploads
